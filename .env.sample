# Copy to .env and fill in. NEVER commit the real .env.

# OpenAI
OPENAI_API_KEY=sk-your-key-here
VECTOR_STORE_ID=vs_xxx
ASSISTANT_ID=asst_xxx

# Zendesk Help Center (public articles API; no auth needed for public content)
ZENDESK_SUBDOMAIN=support.optisigns.com
ZENDESK_LOCALE=en-us

# Chunking
MAX_CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=400

# Daily job: persist the delta manifest back to the repo (optional but recommended
# for the deployed job). When both are set, the run commits data/manifest.json via
# the GitHub Contents API (commit subject ends with [skip ci]).
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=owner/repo
GITHUB_BRANCH=master
